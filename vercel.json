{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
       "use": "@vercel/node"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/proxy(?:/(.*))?",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/execute.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key"
  }
}
